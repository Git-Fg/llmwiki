{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "JSON Schema for `llmwiki-cli`'s config file (`Config` and its sub-configs).\nAuto-generated by `build.rs` from the structs in this file (included via\n`include!` from `src/core/config.rs` and from `build.rs`). This file is\nthe single source of truth — do NOT duplicate these structs or their\n`default_*` helpers in `build.rs`.\n\nType imports are intentionally written as full paths on the derive\nattributes (`schemars::JsonSchema`, `serde::Serialize`, etc.) so this\nfile does not need any `use` statements. This keeps the file\nself-contained in any include! scope without introducing duplicate\n`JsonSchema` name collisions when build.rs includes both\n`config_types.rs` and `doctor_report.rs`.",
  "type": "object",
  "properties": {
    "config_version": {
      "type": "integer",
      "format": "uint32",
      "default": 0,
      "minimum": 0
    },
    "nim": {
      "$ref": "#/$defs/NimConfig",
      "default": {
        "api_key_env": "NVIDIA_NIM_API_KEY",
        "base_url": "https://integrate.api.nvidia.com",
        "batch_size": 8,
        "embed_dim_override": null,
        "embed_model": "nvidia/nv-embed-v1",
        "request_timeout_secs": 30,
        "rerank_model": "",
        "retry": {
          "backoff_ms": 0,
          "max_attempts": 0
        }
      }
    },
    "wiki": {
      "$ref": "#/$defs/WikiConfig",
      "default": {
        "chunk_overlap_tokens": 128,
        "default_chunk_tokens": 512,
        "min_chunk_tokens": 32,
        "pages_dir": "wiki",
        "require_frontmatter": true,
        "require_wikilinks_min": 2
      }
    }
  },
  "$defs": {
    "NimConfig": {
      "type": "object",
      "properties": {
        "api_key_env": {
          "type": "string",
          "default": "NVIDIA_NIM_API_KEY"
        },
        "base_url": {
          "type": "string",
          "default": "https://integrate.api.nvidia.com"
        },
        "batch_size": {
          "type": "integer",
          "format": "uint",
          "default": 8,
          "minimum": 0
        },
        "embed_dim_override": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "default": null,
          "minimum": 0
        },
        "embed_model": {
          "type": "string",
          "default": "nvidia/nv-embed-v1"
        },
        "request_timeout_secs": {
          "type": "integer",
          "format": "uint64",
          "default": 30,
          "minimum": 0
        },
        "rerank_model": {
          "type": "string",
          "default": ""
        },
        "retry": {
          "$ref": "#/$defs/RetryConfig",
          "default": {
            "backoff_ms": 0,
            "max_attempts": 0
          }
        }
      }
    },
    "RetryConfig": {
      "type": "object",
      "properties": {
        "backoff_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 500,
          "minimum": 0
        },
        "max_attempts": {
          "type": "integer",
          "format": "uint32",
          "default": 3,
          "minimum": 0
        }
      }
    },
    "WikiConfig": {
      "type": "object",
      "properties": {
        "chunk_overlap_tokens": {
          "type": "integer",
          "format": "uint",
          "default": 128,
          "minimum": 0
        },
        "default_chunk_tokens": {
          "type": "integer",
          "format": "uint",
          "default": 512,
          "minimum": 0
        },
        "min_chunk_tokens": {
          "type": "integer",
          "format": "uint",
          "default": 32,
          "minimum": 0
        },
        "pages_dir": {
          "description": "Directory (relative to workspace root) containing wiki pages.\nDefault `\"wiki\"` keeps backward compatibility with `wiki init`-created\nwikis (which create a `wiki/` subdirectory). Set to `\"\"` (empty\nstring) for **flat-layout** Karpathy-style wikis where pages live at\nthe workspace root (e.g. `comparisons/foo.md`, `queries/bar.md`,\n`index.md`). v0.3.25+ — surfaced by the pre-release real-wiki smoke\ntest (see `AGENTS.md` \"Pre-release real-wiki smoke test\").",
          "type": "string",
          "default": "wiki"
        },
        "require_frontmatter": {
          "type": "boolean",
          "default": true
        },
        "require_wikilinks_min": {
          "type": "integer",
          "format": "uint",
          "default": 2,
          "minimum": 0
        }
      }
    }
  }
}
